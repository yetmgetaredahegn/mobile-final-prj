rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper to check if user is authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper to check if the document belongs to the authenticated shop owner
    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // ── Users Collection ──────────────────────────────────
    match /users/{userId} {
      allow read, write: if isSignedIn() && isOwner(userId);
    }

    // ── Customers Collection ──────────────────────────────
    // Each customer document has a shopOwnerId field
    match /customers/{customerId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.shopOwnerId);
      allow create: if isSignedIn() && isOwner(request.resource.data.shopOwnerId);
    }

    // ── Transactions Collection ───────────────────────────
    // Each transaction document has a shopOwnerId field
    match /transactions/{transactionId} {
      allow read, write: if isSignedIn() && isOwner(resource.data.shopOwnerId);
      allow create: if isSignedIn() && isOwner(request.resource.data.shopOwnerId);
    }
  }
}
